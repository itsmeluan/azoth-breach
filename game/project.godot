; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="AZOTH: BREACH"
config/description="Vertical slice de AZOTH: BREACH — build local-first, iOS como plataforma prioritária."
run/main_scene="res://scenes/app/app_shell.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[autoload]

SliceState="*res://scripts/state/slice_state.gd"
TelemetryLogger="*res://scripts/services/telemetry_logger.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=810
window/size/window_height_override=1440
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
textures/canvas_textures/default_texture_filter=0
